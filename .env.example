# ---- Copy this file to `.env` and fill in your values ----

# OpenRouter API key — used by all agents. Free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model for all agents (default is a free Gemma model on OpenRouter)
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# LLM sampling temperature (optional)
LLM_TEMPERATURE=0.2

# HuggingFace embedding model for the Knowledge Agent (optional; has a default)
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Groq API key — ONLY needed for voice input (STT). Free key: https://console.groq.com/keys
# Leave blank if you don't use the microphone; text chat and spoken replies (TTS) work without it.
GROQ_API_KEY=

# Logging level: DEBUG | INFO | WARNING | ERROR (optional)
LOG_LEVEL=INFO
